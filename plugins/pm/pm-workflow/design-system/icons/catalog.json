  "source": "figma-developer-mcp",
  "note": "Outbound icon manifest. Icons are a distinct asset class from components — they're single SVG files with no variants/modifiers/slots, only color theming via `currentColor`. Downstream agents read this separately from components.json. Primary fill is normalized to `currentColor` so `color: var(--anything)` in the consuming context themes the icon. Some icons retain a secondary hardcoded color (#666666 / #797979) for deliberate two-tone visuals; those are listed in `secondaryColors`. Default visual color matches Figma's design (light theme #333333 base).",
  "schema": {
    "icons[]": {
      "name": "string · kebab-case ASCII, matches <name>.svg filename",
      "displayName": "string · raw Figma component name (often Chinese)",
      "category": "string · icon page slug (matches icons/<category>/ subfolder)",
      "figmaNodeId": "string · e.g. '40:50'",
      "figmaSourceUrl": "string · deep link to the Figma node",
      "file": "string · SVG path relative to repo root",
      "size": "object · { width: number, height: number } in px (viewBox dimensions)",
      "defaultColor": "string · CSS color value of the icon's primary fill — usually 'currentColor' so `color:` propagates",
      "secondaryColors": "string[] · any non-themeable hardcoded colors (e.g. ['#666666']); empty array if single-color",
      "tokensReferenced": "string[] · semantic CSS vars downstream should map to the icon (typically the text-color tokens to set via `color:`)",
      "hash": "string · sha1 of the SVG file content",
      "generatedAt": "string · ISO 8601"
    }
  },
